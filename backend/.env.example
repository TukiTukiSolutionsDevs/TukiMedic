# Database
DATABASE_URL=postgresql+asyncpg://medagent:medagent@localhost:5432/medagent

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-in-production

# LLM APIs
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=medagent-documents

# WebSocket / CORS
# Comma-separated list of allowed origins for CORS middleware and WS origin guard.
# In production, set this to your frontend domain (e.g. https://your-domain.com).
ALLOWED_ORIGINS=http://localhost:3000

# CORS + WebSocket
# Comma-separated list of allowed origins for CORS middleware and WebSocket origin guard.
# In production, set this to your actual frontend URL(s).
# The WS endpoint /api/v1/chat/ws checks the Origin header against this list.
ALLOWED_ORIGINS=["http://localhost:3000"]
