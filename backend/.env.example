# Database
DATABASE_URL=postgresql+asyncpg://medagent:medagent@localhost:5432/medagent

# Redis
REDIS_URL=redis://localhost:6379/0

# Environment marker — drives validation in app.core.config.
# Use "production" only in real production deployments.
ENVIRONMENT=development

# Auth
# SECRET_KEY MUST be at least 32 chars and high-entropy. The app refuses to
# boot with placeholder values like "change-me-in-production".
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-me-with-secrets-token-urlsafe-48-output-of-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encrypted API key vault (S4.0.c)
# AES-256-GCM master key — must decode to exactly 32 bytes. App refuses to
# boot without this. Generate with:
#   python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
VAULT_MASTER_KEY=replace-me-with-base64-encoded-32-byte-key

# LLM APIs (stored in vault after S4.0.c — these become optional fallbacks)
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=medagent-documents

# CORS + WebSocket
# JSON list of allowed origins for CORS middleware and WebSocket origin guard.
# In production, set this to your actual frontend URL(s), e.g.
# ALLOWED_ORIGINS=["https://your-domain.com"]
ALLOWED_ORIGINS=["http://localhost:3000"]
